    "@radix-ui/react-slot": "^1.1.1",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.90.21",
    "bullmq": "^5.34.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.474.0",
    "next": "^15.2.0",
    "next-auth": "^4.24.11",
    "openai": "^4.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
