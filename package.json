{
  "name": "reelsearch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "worker": "npx tsx src/workers/reel-processor.ts",
    "worker:dev": "npx tsx --watch src/workers/reel-processor.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:phase1": "vitest run tests/phase-1",
    "test:phase2": "vitest run tests/phase-2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
